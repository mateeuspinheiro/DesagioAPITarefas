program gerenciadorTarefas;

{$APPTYPE CONSOLE}

{$R *.res}

uses
  Horse,
  AppConfig in 'src\Config\AppConfig.pas',
  Entidade.Tarefa in 'src\Domain\Entidade.Tarefa.pas',
  Enums.Tarefa in 'src\Domain\Enums.Tarefa.pas';

begin
  try
    Writeln('Iniciando a API do Gerenciador de Tarefas');
    Writeln('.....');
    Writeln('Para finalizar o serviþo, pressione Ctrl+C para encerrar');

    THorse.Use({middle});
    Registry;

    THorse.Listen(TAppConfig.Instance.Port);
  except

  end;
  THorse.Get('ping',
    procedure(Req: THorseRequest; Res: THorseResponse)
    begin
      Res.Send('pong');
    end);

  THorse.Listen(9000);
end.
